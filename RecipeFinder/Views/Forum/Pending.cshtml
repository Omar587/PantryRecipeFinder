@{
    ViewData["Title"] = "Post Submitted";
}

<style>
body, .container, main, .pb-5, .mt-4 { background: #f9f5ef !important; }

.pending-shell {
    max-width: 580px;
    margin: 4rem auto;
    padding: 0 1.5rem;
    text-align: center;
}

.pending-card {
    background: #fdf8f2;
    border-radius: 18px;
    border: 1px solid rgba(180,145,100,0.2);
    box-shadow: 0 2px 8px rgba(100,70,30,0.07), 0 8px 32px rgba(100,70,30,0.06);
    padding: 3rem 2.5rem;
}

.pending-icon {
    font-size: 3.5rem;
    margin-bottom: 1.25rem;
    display: block;
}

.pending-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2rem;
    font-weight: 700;
    color: #1a1208;
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
}

.pending-sub {
    font-size: 0.92rem;
    color: #6b5740;
    line-height: 1.7;
    margin-bottom: 2rem;
}

.pending-sub strong { color: #2a1f14; font-weight: 700; }

.btn-back {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background: #2a1f14;
    color: white;
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.2s;
    box-shadow: 0 2px 8px rgba(42,31,20,0.2);
}

.btn-back:hover {
    background: #e85d26;
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(232,93,38,0.3);
    color: white;
    text-decoration: none;
}
</style>

<div class="pending-shell">
    <div class="pending-card">
        <span class="pending-icon">⏳</span>
        <div class="pending-title">Post Submitted!</div>
        <div class="pending-sub">
            Your post has been submitted and is <strong>pending review</strong>.<br>
            Once approved by a moderator it will appear in the forum.<br>
            This usually happens within 24 hours.
        </div>
        <a asp-controller="Forum" asp-action="Index" class="btn-back">
            ← Back to Forum
        </a>
    </div>
</div>