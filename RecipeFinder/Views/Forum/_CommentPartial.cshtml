@model RecipeFinder.ViewModels.Forum.ForumCommentViewModel
@{
    int depth = ViewData["depth"] as int? ?? 0;

    string Initials(string name) =>
        string.IsNullOrWhiteSpace(name) ? "?" : name[0].ToString().ToUpper();

    string AvatarColor(string name)
    {
        var colors = new[] { "#e85d26","#2d7d46","#c17b1a","#2563eb","#7c3aed","#db2777","#0891b2" };
        return colors[Math.Abs((name ?? "?").GetHashCode()) % colors.Length];
    }

    string TimeAgo(DateTime dt)
    {
        var span = DateTime.UtcNow - dt.ToUniversalTime();
        if (span.TotalMinutes < 1)  return "just now";
        if (span.TotalMinutes < 60) return $"{(int)span.TotalMinutes}m ago";
        if (span.TotalHours   < 24) return $"{(int)span.TotalHours}h ago";
        if (span.TotalDays    < 7)  return $"{(int)span.TotalDays}d ago";
        return dt.ToString("MMM d, yyyy");
    }

    string depthColor = depth switch {
        1 => "#e85d26",
        2 => "#2d7d46",
        3 => "#2563eb",
        4 => "#7c3aed",
        _ => "#db2777"
    };
}

<div class="comment-item @(depth > 0 ? "is-reply" : "")"
     id="comment-@Model.Id"
     data-depth="@depth"
     style="@(depth > 0 ? $"border-left-color:{depthColor}" : "")">

    <div class="comment-top">
        @if (!Model.IsDeleted)
        {
            <div class="avatar avatar-sm" style="background:@AvatarColor(Model.AuthorName); width:28px; height:28px; font-size:0.65rem; border-radius:50%; display:flex; align-items:center; justify-content:center; font-weight:700; color:white; flex-shrink:0;">
                @Initials(Model.AuthorName)
            </div>
        }
        <span class="comment-author">@(Model.IsDeleted ? "[deleted]" : Model.AuthorName)</span>
        <span class="comment-time">@TimeAgo(Model.CreatedAt)</span>
        @if (Model.UpdatedAt.HasValue && !Model.IsDeleted)
        {
            <span class="comment-edited">· edited</span>
        }
    </div>

    <!-- Body -->
    <div id="body-@Model.Id" class="comment-body @(Model.IsDeleted ? "deleted" : "")">
        @(Model.IsDeleted ? "[This comment has been deleted]" : Model.Body)
    </div>

    @if (!Model.IsDeleted)
    {
        <!-- Inline edit form -->
        <div id="edit-wrap-@Model.Id" class="inline-edit-wrap">
            <form asp-controller="ForumComment" asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="commentId" value="@Model.Id" />
                <input type="hidden" name="postId"    value="@ViewData["PostId"]" />
                <textarea name="body">@Model.Body</textarea>
                <div class="comment-form-actions" style="margin-top:0.5rem;">
                    <button type="submit" class="btn-post">Save</button>
                    <button type="button" class="btn-cancel-inline"
                            onclick="toggleEdit(@Model.Id, false)">Cancel</button>
                </div>
            </form>
        </div>

        <!-- Actions -->
        <div class="comment-actions" id="actions-@Model.Id">
            <button class="c-vote-btn up @(Model.UserVote == 1 ? "voted-up" : "")"
                    onclick="voteComment(@Model.Id, 1)" title="Upvote">
                <svg viewBox="0 0 24 24"><polyline points="18 15 12 9 6 15"/></svg>
            </button>
            <span class="c-score @(Model.VoteScore > 0 ? "pos" : Model.VoteScore < 0 ? "neg" : "")"
                  id="cs-@Model.Id">@Model.VoteScore</span>
            <button class="c-vote-btn down @(Model.UserVote == -1 ? "voted-down" : "")"
                    onclick="voteComment(@Model.Id, -1)" title="Downvote">
                <svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>
            </button>

            <div class="c-sep"></div>

            <button class="c-btn" onclick="toggleReply(@Model.Id)">💬 Reply</button>

            @if (Model.CanEdit)
            {
                <div class="c-sep"></div>
                <button class="c-btn" onclick="toggleEdit(@Model.Id, true)">✏️ Edit</button>
                <div class="c-sep"></div>
                <form asp-controller="ForumComment" asp-action="Delete" method="post"
                      style="display:inline"
                      onsubmit="return confirm('Delete this comment?')">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="commentId" value="@Model.Id" />
                    <input type="hidden" name="postId"    value="@ViewData["PostId"]" />
                    <button type="submit" class="c-btn danger">🗑 Delete</button>
                </form>
            }
        </div>

        <!-- Reply form -->
        <div id="reply-wrap-@Model.Id" class="reply-form-wrap">
            <form asp-controller="ForumComment" asp-action="Add" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="ForumPostId"     value="@ViewData["PostId"]" />
                <input type="hidden" name="ParentCommentId" value="@Model.Id" />
                <div style="display:flex; gap:0.65rem; align-items:flex-start;">
                    <textarea name="Body"
                              class="comment-textarea"
                              placeholder="Write a reply…"
                              maxlength="5000"
                              required
                              style="min-height:70px;"></textarea>
                </div>
                <div class="comment-form-actions" style="margin-top:0.5rem;">
                    <button type="submit" class="btn-post">Reply</button>
                    <button type="button" class="btn-cancel-inline"
                            onclick="toggleReply(@Model.Id)">Cancel</button>
                </div>
            </form>
        </div>
    }
</div>

<div class="comment-divider"></div>

<!-- Nested replies -->
@if (Model.Replies.Any())
{
    foreach (var reply in Model.Replies)
    {
        ViewData["depth"] = Math.Min(depth + 1, 5);
        @await Html.PartialAsync("_CommentPartial", reply, ViewData)
    }
}