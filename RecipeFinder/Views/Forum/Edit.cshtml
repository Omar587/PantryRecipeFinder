@model RecipeFinder.ViewModels.Forum.EditPostViewModel
@{
    ViewData["Title"] = "Edit Post";
}

<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

body {
    font-family: 'DM Sans', sans-serif;
    background-color: #f9f5ef;
    color: #1a1a1a;
    -webkit-font-smoothing: antialiased;
}

.page-shell {
    max-width: 740px;
    margin: 0 auto;
    padding: 0 2rem 4rem;
}

.breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 1.5rem 0 1.25rem;
    font-size: 0.8rem;
    color: #8a7f74;
}

.breadcrumb a { color: #8a7f74; text-decoration: none; font-weight: 500; }
.breadcrumb a:hover { color: #e85d26; }
.breadcrumb-sep { color: #c5bdb4; }

.page-hero {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid #c5bdb4;
}

.hero-eyebrow {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #e85d26;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
}

.hero-eyebrow::before {
    content: '';
    display: block;
    width: 32px;
    height: 1px;
    background: #e85d26;
}

.hero-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.6rem, 4vw, 2.5rem);
    font-weight: 300;
    color: #1a1a1a;
    line-height: 1;
}

.hero-title em { font-style: italic; color: #e85d26; }

.form-card {
    background: white;
    border-radius: 16px;
    border: 1px solid rgba(197,189,180,0.4);
    padding: 2rem 2.25rem;
}

.form-section { margin-bottom: 1.75rem; }

.field-label {
    display: block;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #8a7f74;
    margin-bottom: 0.6rem;
}

.field-label .required { color: #e85d26; margin-left: 0.2rem; }

.form-input {
    width: 100%;
    padding: 0.8rem 1rem;
    border: 1px solid #c5bdb4;
    border-radius: 10px;
    background: #f9f5ef;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.95rem;
    color: #1a1a1a;
    transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
}

.form-input:focus {
    outline: none;
    border-color: #e85d26;
    box-shadow: 0 0 0 3px rgba(232,93,38,0.1);
    background: white;
}

.form-input.input-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.01em;
}

.form-textarea {
    width: 100%;
    min-height: 280px;
    padding: 0.9rem 1rem;
    border: 1px solid #c5bdb4;
    border-radius: 10px;
    background: #f9f5ef;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.92rem;
    color: #1a1a1a;
    line-height: 1.7;
    resize: vertical;
    transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
}

.form-textarea:focus {
    outline: none;
    border-color: #e85d26;
    box-shadow: 0 0 0 3px rgba(232,93,38,0.1);
    background: white;
}

.char-counter {
    font-size: 0.72rem;
    color: #c5bdb4;
    text-align: right;
    margin-top: 0.35rem;
    transition: color 0.2s;
}

.char-counter.warn { color: #c17b1a; }
.char-counter.over { color: #c0392b; font-weight: 600; }

.field-validation-error {
    display: block;
    font-size: 0.75rem;
    color: #c0392b;
    margin-top: 0.4rem;
}

.input-validation-error { border-color: #c0392b !important; }

/* Edit notice banner */
.edit-notice {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.85rem 1rem;
    background: #fef0e8;
    border: 1px solid rgba(232,93,38,0.2);
    border-radius: 10px;
    margin-bottom: 1.75rem;
    font-size: 0.82rem;
    color: #c17b1a;
}

.edit-notice svg {
    width: 16px; height: 16px;
    stroke: currentColor; fill: none;
    flex-shrink: 0;
}

.form-submit-row {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.75rem;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid #f0e9dc;
}



.btn-submit {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.8rem 1.75rem;
    background: #1a1a1a;
    color: white;
    border: none;
    border-radius: 10px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s, transform 0.15s;
}

.btn-submit:hover { background: #e85d26; transform: translateY(-1px); }
.btn-submit:active { transform: translateY(0); }

.btn-cancel {
    display: inline-flex;
    align-items: center;
    padding: 0.8rem 1.25rem;
    background: transparent;
    color: #8a7f74;
    border: 1px solid #c5bdb4;
    border-radius: 10px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s;
}

.btn-cancel:hover { border-color: #8a7f74; color: #1a1a1a; text-decoration: none; }

@@media (max-width: 600px) {
    .page-shell { padding: 0 1rem 3rem; }
    .form-card { padding: 1.25rem; }
}
</style>

<div class="page-shell">

    <nav class="breadcrumb">
        <a asp-action="Index">Forum</a>
        <span class="breadcrumb-sep">/</span>
        <a asp-action="Details" asp-route-id="@Model.Id">Post</a>
        <span class="breadcrumb-sep">/</span>
        <span>Edit</span>
    </nav>

    <div class="page-hero">
        <div class="hero-eyebrow">Community</div>
        <h1 class="hero-title"><em>Edit</em> Post</h1>
    </div>

    <div class="form-card">

        <div class="edit-notice">
            <svg viewBox="0 0 24 24" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <line x1="12" y1="8" x2="12" y2="12"/>
                <line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
            Editing a post will mark it as edited for other members.
        </div>

        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div class="form-section">
                <label class="field-label" asp-for="Title">
                    Title <span class="required">*</span>
                </label>
                <input asp-for="Title"
                       class="form-input input-title"
                       placeholder="Post title…"
                       maxlength="300"
                       id="titleInput"
                       autocomplete="off" />
                <div class="char-counter" id="titleCounter">0 / 300</div>
                <span asp-validation-for="Title" class="field-validation-error"></span>
            </div>

            <div class="form-section">
                <label class="field-label" asp-for="Body">
                    Body <span class="required">*</span>
                </label>
                <textarea asp-for="Body"
                          class="form-textarea"
                          maxlength="40000"
                          id="bodyInput"></textarea>
                <div class="char-counter" id="bodyCounter">0 / 40,000</div>
                <span asp-validation-for="Body" class="field-validation-error"></span>
            </div>

            <div class="form-submit-row">
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn-cancel">Cancel</a>
                <button type="submit" class="btn-submit">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
                        <polyline points="17 21 17 13 7 13 7 21"/>
                        <polyline points="7 3 7 8 15 8"/>
                    </svg>
                    Save Changes
                </button>
            </div>
        </form>
    </div>
</div>

<script>
function attachCounter(inputId, counterId, max, warn) {
    const el  = document.getElementById(inputId);
    const ctr = document.getElementById(counterId);
    if (!el || !ctr) return;
    const update = () => {
        const len = el.value.length;
        ctr.textContent = `${len.toLocaleString()} / ${max.toLocaleString()}`;
        ctr.className   = 'char-counter' + (len >= max ? ' over' : len >= warn ? ' warn' : '');
    };
    el.addEventListener('input', update);
    update();
}

const body = document.getElementById('bodyInput');
if (body) {
    body.style.height = Math.max(220, body.scrollHeight) + 'px';
}

attachCounter('titleInput', 'titleCounter', 300, 250);
attachCounter('bodyInput',  'bodyInput',  40000, 35000);
</script>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
