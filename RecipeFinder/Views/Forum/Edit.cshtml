@model RecipeFinder.ViewModels.Forum.EditPostViewModel
@{
    ViewData["Title"] = "Edit Post";
}

<style>
@@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,600;1,300&family=DM+Sans:wght@400;500;700&display=swap');

/* 1. RESTORE ORIGINAL BACKGROUND & FONT */
body {
    font-family: 'DM Sans', sans-serif;
    background-color: #f9f5ef; /* Restored original beige */
    color: #1a1a1a;
    margin: 0;
}

.page-shell {
    max-width: 900px; 
    margin: 0 auto;
    padding: 1rem 1.5rem 2rem; /* Reduced top padding to save space */
}

/* 2. BOLD TITLE & COMPACT HERO */
.page-hero {
    margin-bottom: 1.5rem;
    border-bottom: 1px solid #c5bdb4;
    padding-bottom: 0.5rem;
}

.hero-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.5rem;
    font-weight: 700; /* Made it Bold as requested */
    color: #1a1a1a;
}

.hero-title em { font-style: italic; color: #e85d26; font-weight: 300; }

/* 3. COMPACT CARD */
.form-card {
    background: white;
    border-radius: 16px;
    border: 1px solid rgba(197,189,180,0.4);
    padding: 1.5rem 2rem; /* Reduced from 3.5rem to stop over-scrolling */
}

.form-section {
    margin-bottom: 1.2rem; /* Tighter spacing */
}

.field-label {
    display: block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #8a7f74;
    margin-bottom: 0.5rem;
}

/* 4. INPUTS */
.form-input, .form-textarea {
    width: 100%;
    display: block;
    padding: 0.8rem 1rem;
    border: 1px solid #c5bdb4;
    border-radius: 10px;
    background: #f9f5ef; /* Restored original input background */
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
}

.input-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.4rem;
    font-weight: 700; /* Bold Title Input */
}

/* Textarea height reduced to prevent vertical scrolling */
.form-textarea {
    min-height: 250px; /* Reduced from 450px */
    line-height: 1.6;
    resize: vertical;
}

.form-input:focus, .form-textarea:focus {
    outline: none;
    border-color: #e85d26;
    background: white;
}

/* 5. BUTTONS */
.form-submit-row {
    display: flex;
    justify-content: flex-end;
    gap: 1rem;
    margin-top: 1.5rem;
    padding-top: 1rem;
    border-top: 1px solid #f0e9dc;
}

.btn-submit {
    padding: 0.8rem 2rem;
    background: #1a1a1a;
    color: white;
    border: none;
    border-radius: 10px;
    font-weight: 700;
    text-transform: uppercase;
    cursor: pointer;
}

.btn-submit:hover { background: #e85d26; }

.btn-cancel {
    padding: 0.8rem 1rem;
    color: #8a7f74;
    text-decoration: none;
    font-size: 0.9rem;
}

.char-counter {
    text-align: right;
    font-size: 0.7rem;
    color: #c5bdb4;
    margin-top: 0.3rem;
}
</style>

<div class="page-shell">
    <div class="page-hero">
        <h1 class="hero-title">Update <em>Post</em></h1>
    </div>

    <div class="form-card">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div class="form-section">
                <label class="field-label">Title</label>
                <input asp-for="Title" class="form-input input-title" id="titleInput" />
                <div class="char-counter" id="titleCounter">0 / 300</div>
            </div>

            <div class="form-section">
                <label class="field-label">Body Content</label>
                <textarea asp-for="Body" class="form-textarea" id="bodyInput"></textarea>
                <div class="char-counter" id="bodyCounter">0 / 40,000</div>
            </div>

            <div class="form-submit-row">
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn-cancel">Cancel</a>
                <button type="submit" class="btn-submit">Save Changes</button>
            </div>
        </form>
    </div>
</div>

<script>
    function setupCounter(inputId, counterId, max) {
        const input = document.getElementById(inputId);
        const counter = document.getElementById(counterId);
        if (!input || !counter) return;
        const update = () => {
            counter.textContent = `${input.value.length.toLocaleString()} / ${max.toLocaleString()}`;
        };
        input.addEventListener('input', update);
        update();
    }
    setupCounter('titleInput', 'titleCounter', 300);
    setupCounter('bodyInput', 'bodyCounter', 40000);
</script>