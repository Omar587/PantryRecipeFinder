    border-bottom: 1px solid rgba(255,255,255,0.04);
    transition: background 0.25s ease, color 0.25s ease;
    border-radius: 2px;
    cursor: default;
}

.cta-perk-row:last-child { border-bottom: none; }

.cta-perk-row:hover {
    background: rgba(232,93,38,0.06);
    color: rgba(255,255,255,0.8);
    padding-left: 0.5rem;
}

