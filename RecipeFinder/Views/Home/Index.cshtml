<!-- ══════════════════════════════════════════════ MARQUEE ══ -->
<div class="marquee-strip" aria-hidden="true">
    <div class="marquee-track">
        @{
            var marqueeItems = new[] { "Italian","French","Japanese","Mexican","Indian","Thai","Mediterranean","Chinese","Greek","Spanish","Korean","Moroccan","Lebanese","American","Vietnamese" };
            // Duplicate for seamless loop
            for (int pass = 0; pass < 2; pass++)
            {
                foreach (var item in marqueeItems)
                {
                    <span class="marquee-item">
                        <span class="dot"></span>
                        @item cuisine
                    </span>
                }
            }
        }
    </div>
</div>


<!-- ══════════════════════════════════════════ FEATURED RECIPES ══ -->
<div class="section">
    <div class="section-row">
        <div class="section-head reveal">
            <div class="section-head-left">
                <div class="eyebrow">Curated Picks</div>
                <div class="section-title-block">
                    <h2>This Week's <em>Finest</em></h2>
                </div>
            </div>
            <a href="/Recipe" class="section-see-all">
                View All Recipes
                <svg viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12"/>
                    <polyline points="12 5 19 12 12 19"/>
                </svg>
            </a>
        </div>

        <div class="recipe-row">
            @{
                // Render top-rated recipe cards from ViewBag if available, else placeholders
                var featuredRecipes = ViewBag.FeaturedRecipes as IEnumerable<RecipeFinder.Models.Recipe>;
                if (featuredRecipes != null && featuredRecipes.Any())
                {
                    int idx = 0;
                    foreach (var recipe in featuredRecipes.Take(4))
                    {
                        string badgeClass = recipe.Difficulty.ToString() switch {
                            "Easy" => "badge-easy",
                            "Hard" => "badge-hard",
                            _ => "badge-medium"
                        };
                        <article class="r-card reveal reveal-d@(idx+1)" onclick="window.location='@Url.Action("Details","Recipe",new{id=recipe.Id})'">
                            <div class="r-card-img">
                                <img src="@recipe.ImageUrl" alt="@recipe.Name" loading="lazy" />
                                <span class="r-badge @badgeClass">@recipe.Difficulty</span>
                                <span class="r-cuisine">@recipe.Cuisine</span>
                            </div>
                            <div class="r-body">
                                <h3 class="r-name">@recipe.Name</h3>
                                <div class="r-meta">
                                    <span>@recipe.TotalTime() min</span>
                                    <span class="r-meta-sep">·</span>
                                    <span>@recipe.Servings servings</span>
                                </div>
                                <div class="r-rating">
                                    <span class="r-stars">★★★★★</span>
                                    <span class="r-rating-num">@recipe.Rating.ToString("F1")</span>
                                    <span class="r-rating-count">(@recipe.RatingCount)</span>
                                </div>
                            </div>
                        </article>
                        idx++;
                    }
                }
                else
                {
                    // Placeholder cards for when ViewBag is not wired
                    var placeholders = new[] {
                        new { Name="Spaghetti Carbonara", Cuisine="Italian",  Time="30", Rating="4.8", Count="214", Diff="Easy",   Img="https://images.unsplash.com/photo-1612874742237-6526221588e3?w=600&q=80" },
                        new { Name="Beef Rendang",         Cuisine="Indonesian",Time="90",Rating="4.9",Count="87",  Diff="Hard",   Img="https://images.unsplash.com/photo-1585937421612-70a008356fbe?w=600&q=80" },
                        new { Name="Pad Thai",             Cuisine="Thai",     Time="25", Rating="4.7", Count="156", Diff="Medium", Img="https://images.unsplash.com/photo-1559314809-0d155014e29e?w=600&q=80" },
                        new { Name="Shakshuka",            Cuisine="Middle Eastern",Time="20",Rating="4.6",Count="98",Diff="Easy", Img="https://images.unsplash.com/photo-1590301157890-4810ed352733?w=600&q=80" },
                    };
                    int pi = 0;
                    foreach (var p in placeholders)
                    {
                        string bc = p.Diff == "Easy" ? "badge-easy" : p.Diff == "Hard" ? "badge-hard" : "badge-medium";
                        <article class="r-card reveal reveal-d@(pi+1)" style="cursor:pointer" onclick="window.location='/Recipe'">
                            <div class="r-card-img">
                                <img src="@p.Img" alt="@p.Name" loading="lazy" />
                                <span class="r-badge @bc">@p.Diff</span>
                                <span class="r-cuisine">@p.Cuisine</span>
                            </div>
                            <div class="r-body">
                                <h3 class="r-name">@p.Name</h3>
                                <div class="r-meta">
                                    <span>@p.Time min</span>
                                    <span class="r-meta-sep">·</span>
                                    <span>4 servings</span>
                                </div>
                                <div class="r-rating">
                                    <span class="r-stars">★★★★★</span>
                                    <span class="r-rating-num">@p.Rating</span>
                                    <span class="r-rating-count">(@p.Count)</span>
                                </div>
                            </div>
                        </article>
                        pi++;
                    }
                }
            }
        </div>
    </div>
</div>


<!-- ══════════════════════════════════════ EDITORIAL / FORUM ══ -->
<div class="section">
    <div class="editorial-split reveal">
        <div class="ed-image-side">
