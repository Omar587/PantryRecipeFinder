@{
    ViewData["Title"] = "Home — RecipeFinder";
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400;1,600&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">

<style>
/* ─── RESET & BASE ─────────────────────────────────────────── */
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

html { scroll-behavior: smooth; }

body {
    font-family: 'DM Sans', system-ui, sans-serif;
    background: #f9f5ef;
    color: #1a1a1a;
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
}

/* ─── UTILITY ──────────────────────────────────────────────── */
.eyebrow {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: #e85d26;
    display: flex;
    align-items: center;
    gap: 0.75rem;
}
.eyebrow::before {
    content: '';
    display: block;
    width: 28px;
    height: 1px;
    background: #e85d26;
    flex-shrink: 0;
}

/* ─── HERO ─────────────────────────────────────────────────── */

.hero {
    position: relative;
    height: 100svh;
    min-height: 640px;
    max-height: 920px;
    /* ADD these two: */
    max-width: 1480px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 52% 48%;
    overflow: hidden;
}

.hero-left {
    position: relative;
    z-index: 2;
    background: #f9f5ef;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    /* CHANGE padding to match nav's 2rem left edge */
    padding: 2.5rem 3.5rem 2.5rem 2rem;
}

/* Top bar */
.hero-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    opacity: 0;
    animation: riseIn 0.5s 0.05s cubic-bezier(0.4,0,0.2,1) forwards;
}
.hero-issue-tag {
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #8a7f74;
    padding: 0.28rem 0.75rem;
    border: 1px solid #c5bdb4;
    border-radius: 2px;
}
.hero-issue-date {
    font-size: 0.62rem;
    color: #8a7f74;
    letter-spacing: 0.12em;
    text-transform: uppercase;
}

/* Centre block */
.hero-center {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 1.5rem 0;
}

.hero-kicker {
    opacity: 0;
    animation: riseIn 0.5s 0.15s cubic-bezier(0.4,0,0.2,1) forwards;
    margin-bottom: 1rem;
}

.hero-headline {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(3.4rem, 4.8vw, 6rem);
    font-weight: 300;
    line-height: 1.0;
    letter-spacing: -0.03em;
    color: #1a1a1a;
    margin-bottom: 1.5rem;
    opacity: 0;
    animation: riseIn 0.6s 0.25s cubic-bezier(0.4,0,0.2,1) forwards;
}
.hero-headline em {
    font-style: italic;
    color: #e85d26;
}

.hero-sub {
    font-size: 0.9rem;
    line-height: 1.72;
    color: #8a7f74;
    max-width: 360px;
    margin-bottom: 2rem;
    font-weight: 300;
    opacity: 0;
    animation: riseIn 0.5s 0.38s cubic-bezier(0.4,0,0.2,1) forwards;
}

.hero-cta-row {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    opacity: 0;
    animation: riseIn 0.5s 0.48s cubic-bezier(0.4,0,0.2,1) forwards;
}

.btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    padding: 1rem 2rem;
    background: #1a1a1a;
    color: #ffffff;
    text-decoration: none;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border-radius: 2px;
    transition: background 0.25s, transform 0.2s;
}
.btn-primary:hover {
    background: #e85d26;
    transform: translateY(-2px);
}
.btn-primary svg { width: 14px; height: 14px; stroke: currentColor; fill: none; transition: transform 0.2s; }
.btn-primary:hover svg { transform: translateX(4px); }

.btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.82rem;
    font-weight: 600;
    color: #3a3530;
    text-decoration: none;
    letter-spacing: 0.05em;
    border-bottom: 1px solid #c5bdb4;
    padding-bottom: 2px;
    transition: color 0.2s, border-color 0.2s;
}
.btn-ghost:hover { color: #e85d26; border-color: #e85d26; }

.hero-stats {
    display: flex;
    gap: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid #e8ddd0;
    opacity: 0;
    animation: riseIn 0.5s 0.6s cubic-bezier(0.4,0,0.2,1) forwards;
}
.stat-num {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 2rem;
    font-weight: 300;
    line-height: 1;
    color: #1a1a1a;
    display: block;
}
.stat-label {
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #8a7f74;
    margin-top: 0.3rem;
    display: block;
}

/* Right image mosaic */
.hero-right {
    position: relative;
    overflow: hidden;
    opacity: 0;
    animation: fadeIn 1s 0.2s ease forwards;
}

.hero-mosaic {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 2px;
}

.mosaic-cell {
    overflow: hidden;
    position: relative;
}
.mosaic-cell img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 8s ease;
    filter: brightness(0.88) saturate(1.05);
}
.mosaic-cell:hover img { transform: scale(1.04); }
.mosaic-cell:first-child { grid-row: 1 / 3; }

.mosaic-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(232,93,38,0.08), transparent 60%);
    pointer-events: none;
}


/* Vertical marquee ticker on hero edge */
.hero-ticker {
    position: absolute;
    right: 0;
    top: 0;
    bottom: 0;
    width: 2rem;
    background: #e85d26;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 20;
    overflow: hidden;
}
.ticker-text {
    writing-mode: vertical-rl;
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.75);
    white-space: nowrap;
    animation: scrollTicker 12s linear infinite;
}
@@keyframes scrollTicker {
    from { transform: translateY(100%); }
    to   { transform: translateY(-100%); }
}

/* ─── MARQUEE STRIP ────────────────────────────────────────── */
.marquee-strip {
    max-width: 1480px;
    margin: 0 auto;
    background: #1a1a1a;
    padding: 0.9rem 0;
    overflow: hidden;
    position: relative;
    border-radius: 0 0 4px 4px;
}
.marquee-track {
    display: flex;
    gap: 0;
    animation: marqueeScroll 28s linear infinite;
    width: max-content;
}
.marquee-item {
    display: inline-flex;
    align-items: center;
    gap: 1.25rem;
    padding: 0 2rem;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.55);
    white-space: nowrap;
}
.marquee-item .dot {
    width: 4px; height: 4px;
    border-radius: 50%;
    background: #e85d26;
    flex-shrink: 0;
}
@@keyframes marqueeScroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
}

/* ─── FEATURED SECTION ─────────────────────────────────────── */
.section {
    max-width: 1480px;
    margin: 0 auto;
    padding: 0 2rem;
}

.section-row {
    padding: 5rem 0 4rem;
}

.section-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 2.75rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid #c5bdb4;
}

.section-head-left {}

.section-title-block {
    margin-top: 0.75rem;
}

.section-title-block h2 {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(2rem, 3.5vw, 3.2rem);
    font-weight: 300;
    line-height: 1.0;
    letter-spacing: -0.02em;
    color: #1a1a1a;
}
.section-title-block h2 em {
    font-style: italic;
    color: #e85d26;
}

.section-see-all {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.78rem;
    font-weight: 600;
    color: #8a7f74;
    text-decoration: none;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding-bottom: 2px;
    border-bottom: 1px solid #c5bdb4;
    transition: color 0.2s, border-color 0.2s;
    white-space: nowrap;
    flex-shrink: 0;
}
.section-see-all:hover { color: #e85d26; border-color: #e85d26; }
.section-see-all svg { width: 13px; height: 13px; stroke: currentColor; fill: none; transition: transform 0.2s; }
.section-see-all:hover svg { transform: translateX(3px); }

/* ─── RECIPE CARDS ─────────────────────────────────────────── */
.recipe-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
}

.r-card {
    background: #ffffff;
    border-radius: 3px;
    overflow: hidden;
    border: 1px solid rgba(197,189,180,0.4);
    transition: transform 0.35s cubic-bezier(0.34,1.2,0.64,1), box-shadow 0.3s ease, border-color 0.3s;
    cursor: pointer;
    display: flex;
    flex-direction: column;
}
.r-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 24px 56px rgba(26,26,26,0.1), 0 4px 16px rgba(232,93,38,0.1);
    border-color: rgba(232,93,38,0.25);
}

.r-card-img {
    position: relative;
    height: 200px;
    overflow: hidden;
    background: #f0e9dc;
}
.r-card-img img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.4,0,0.2,1);
    display: block;
}
.r-card:hover .r-card-img img { transform: scale(1.07); }

.r-badge {
    position: absolute;
    top: 0.85rem; left: 0.85rem;
    padding: 0.28rem 0.7rem;
    border-radius: 2px;
    font-size: 0.63rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
}
.badge-easy   { background: rgba(255,255,255,0.93); color: #2a7d46; }
.badge-medium { background: rgba(255,255,255,0.93); color: #b87318; }
.badge-hard   { background: rgba(255,255,255,0.93); color: #b83230; }

.r-cuisine {
    position: absolute;
    bottom: 0.85rem; right: 0.85rem;
    padding: 0.28rem 0.7rem;
    background: rgba(26,26,26,0.78);
    color: rgba(255,255,255,0.88);
    border-radius: 2px;
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    backdrop-filter: blur(6px);
}

.r-body {
    padding: 1.2rem 1.25rem 1.3rem;
    display: flex;
    flex-direction: column;
    flex: 1;
}

.r-name {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 1.2rem;
    font-weight: 600;
    line-height: 1.2;
    color: #1a1a1a;
    margin-bottom: 0.75rem;
    letter-spacing: -0.01em;
    transition: color 0.2s;
}
.r-card:hover .r-name { color: #e85d26; }

.r-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.76rem;
    color: #8a7f74;
    margin-bottom: 1rem;
    flex-wrap: wrap;
}
.r-meta-sep { color: #c5bdb4; }

.r-rating {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    margin-top: auto;
    padding-top: 0.85rem;
    border-top: 1px solid #f0e9dc;
}
.r-stars { color: #e85d26; font-size: 0.72rem; letter-spacing: 0.05em; }
.r-rating-num { font-size: 0.78rem; font-weight: 600; color: #3a3530; }
.r-rating-count { font-size: 0.72rem; color: #8a7f74; }

/* ─── EDITORIAL SPLIT ──────────────────────────────────────── */
.editorial-split {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 0;
    background: #1a1a1a;
    overflow: hidden;
    border-radius: 4px;
    margin: 0 0 5rem;
}

.ed-image-side {
    position: relative;
    min-height: 520px;
    overflow: hidden;
}
.ed-image-side img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center;
    filter: brightness(0.75) saturate(1.1);
    transition: transform 7s ease;
}
.ed-image-side:hover img { transform: scale(1.04); }
.ed-image-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, transparent 50%, rgba(26,26,26,0.9) 100%);
}

.ed-content-side {
    padding: 4rem 3.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
}

.ed-label {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #e85d26;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
}
.ed-label::before { content: ''; display: block; width: 24px; height: 1px; background: #e85d26; }

.ed-headline {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(2rem, 2.5vw, 2.8rem);
    font-weight: 300;
    line-height: 1.1;
    color: #ffffff;
    margin-bottom: 1.25rem;
    letter-spacing: -0.02em;
}
.ed-headline em { font-style: italic; color: #e85d26; }

.ed-body {
    font-size: 0.92rem;
    line-height: 1.75;
    color: rgba(255,255,255,0.6);
    margin-bottom: 2rem;
    font-weight: 300;
    max-width: 380px;
}

.ed-forum-preview {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    margin-bottom: 2rem;
}

.ed-forum-thread {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1rem 1.25rem;
    background: rgba(255,255,255,0.05);
    border-radius: 3px;
    border: 1px solid rgba(255,255,255,0.08);
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
    text-decoration: none;
}
.ed-forum-thread:hover {
    background: rgba(255,255,255,0.09);
    border-color: rgba(232,93,38,0.3);
}

.thread-avatar {
    width: 32px; height: 32px;
    border-radius: 50%;
    background: #e85d26;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 700;
    color: #ffffff;
}

.thread-info {}
.thread-title {
    font-size: 0.85rem;
    font-weight: 500;
    color: rgba(255,255,255,0.85);
    line-height: 1.3;
    margin-bottom: 0.3rem;
}
.thread-meta {
    font-size: 0.7rem;
    color: rgba(255,255,255,0.35);
    display: flex;
    gap: 0.75rem;
}
.thread-hot {
    color: #e85d26;
    font-weight: 600;
}

/* ─── CUISINES GRID ────────────────────────────────────────── */
.cuisines-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1rem;
}

.cuisine-card {
    position: relative;
    height: 160px;
    border-radius: 3px;
    overflow: hidden;
    cursor: pointer;
    text-decoration: none;
    display: block;
}
.cuisine-card:hover .cuisine-img { transform: scale(1.08); }
.cuisine-card:hover .cuisine-overlay { opacity: 0.75; }

.cuisine-img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.4,0,0.2,1);
    filter: brightness(0.7) saturate(1.1);
}
.cuisine-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(26,26,26,0.92) 0%, rgba(26,26,26,0.1) 60%);
    transition: opacity 0.3s;
}
.cuisine-label {
    position: absolute;
    bottom: 0.9rem;
    left: 0;
    right: 0;
    text-align: center;
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 1rem;
    font-weight: 600;
    color: #ffffff;
    letter-spacing: 0.02em;
}
.cuisine-count {
    display: block;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 0.62rem;
    font-weight: 400;
    color: rgba(255,255,255,0.55);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-top: 0.2rem;
}

/* ─── COMMUNITY SECTION ────────────────────────────────────── */
.community-band {
    background: #f0e9dc;
    border-top: 1px solid #c5bdb4;
    border-bottom: 1px solid #c5bdb4;
    padding: 4.5rem 0;
    margin-bottom: 5rem;
    overflow: hidden;
    position: relative;
}

.community-inner {
    max-width: 1480px;
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
}

.community-left {}

.community-headline {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(2.2rem, 3.5vw, 3.4rem);
    font-weight: 300;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: #1a1a1a;
    margin: 0.85rem 0 1.25rem;
}
.community-headline em { font-style: italic; color: #e85d26; }

.community-body {
    font-size: 0.95rem;
    line-height: 1.75;
    color: #8a7f74;
    font-weight: 300;
    max-width: 420px;
    margin-bottom: 2rem;
}

.feature-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    margin-bottom: 2.25rem;
}
.feature-item {
    display: flex;
    align-items: flex-start;
    gap: 0.9rem;
    font-size: 0.9rem;
    color: #3a3530;
    line-height: 1.5;
}
.feature-icon {
    width: 28px; height: 28px;
    border-radius: 50%;
    background: #fef0e8;
    border: 1px solid rgba(232,93,38,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 0.1rem;
    font-size: 0.75rem;
}

.community-right {
    position: relative;
}

.forum-card-stack {
    display: flex;
    flex-direction: column;
    gap: 1px;
    border: 1px solid #c5bdb4;
    border-radius: 4px;
    overflow: hidden;
    background: #c5bdb4;
}

.forum-thread-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.1rem 1.4rem;
    background: #ffffff;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.18s;
}
.forum-thread-row:hover { background: #fef0e8; }
.forum-thread-row:hover .ftr-title { color: #e85d26; }

.ftr-avatar {
    width: 36px; height: 36px;
    border-radius: 50%;
    flex-shrink: 0;
    overflow: hidden;
    background: #f0e9dc;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.8rem;
    color: #e85d26;
    border: 2px solid #e8ddd0;
}

.ftr-content { flex: 1; min-width: 0; }
.ftr-title {
    font-size: 0.88rem;
    font-weight: 500;
    color: #1a1a1a;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color 0.18s;
    margin-bottom: 0.22rem;
}
.ftr-meta {
    font-size: 0.7rem;
    color: #8a7f74;
    display: flex;
    align-items: center;
    gap: 0.6rem;
}
.ftr-tag {
    background: #f0e9dc;
    padding: 0.1rem 0.5rem;
    border-radius: 2px;
    font-weight: 500;
    color: #3a3530;
    font-size: 0.65rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
}

.ftr-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.2rem;
    flex-shrink: 0;
}
.ftr-replies {
    font-size: 0.72rem;
    font-weight: 600;
    color: #3a3530;
}
.ftr-replies-label {
    font-size: 0.62rem;
    color: #8a7f74;
    text-transform: uppercase;
    letter-spacing: 0.08em;
}

/* ─── HOW IT WORKS ─────────────────────────────────────────── */
.steps-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border: 1px solid #c5bdb4;
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 5rem;
}

.step-item {
    padding: 2.5rem 2rem;
    border-right: 1px solid #c5bdb4;
    position: relative;
    transition: background 0.2s;
}
.step-item:last-child { border-right: none; }
.step-item:hover { background: #fef0e8; }

.step-number {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 4rem;
    font-weight: 300;
    line-height: 1;
    color: #e8ddd0;
    position: absolute;
    top: 1.5rem;
    right: 1.75rem;
    letter-spacing: -0.05em;
    transition: color 0.2s;
}
.step-item:hover .step-number { color: rgba(232,93,38,0.15); }

.step-icon {
    width: 44px; height: 44px;
    background: #1a1a1a;
    border-radius: 3px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
    transition: background 0.2s;
}
.step-item:hover .step-icon { background: #e85d26; }
.step-icon svg { width: 20px; height: 20px; stroke: white; fill: none; }

.step-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 1.25rem;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 0.6rem;
}
.step-desc {
    font-size: 0.85rem;
    line-height: 1.65;
    color: #8a7f74;
    font-weight: 300;
}

/* ─── CTA BANNER ───────────────────────────────────────────── */
.cta-banner {
    background: #1a1a1a;
    border-radius: 4px;
    padding: 5rem 4rem;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 3rem;
    margin-bottom: 5rem;
    position: relative;
    overflow: hidden;
}

.cta-banner::before {
    content: 'JOIN';
    position: absolute;
    right: -1rem;
    top: 50%;
    transform: translateY(-50%);
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 16rem;
    font-weight: 300;
    color: transparent;
    -webkit-text-stroke: 1px rgba(255,255,255,0.04);
    line-height: 1;
    pointer-events: none;
    user-select: none;
    letter-spacing: -0.04em;
}

.cta-eyebrow {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #e85d26;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
}
.cta-eyebrow::before { content: ''; display: block; width: 24px; height: 1px; background: #e85d26; }

.cta-headline {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(2rem, 3vw, 3rem);
    font-weight: 300;
    color: #ffffff;
    line-height: 1.05;
    letter-spacing: -0.02em;
}
.cta-headline em { font-style: italic; color: #e85d26; }

.cta-buttons {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    align-items: flex-end;
}

.btn-cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    padding: 1rem 2.25rem;
    background: #e85d26;
    color: #ffffff;
    text-decoration: none;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-radius: 2px;
    transition: background 0.2s, transform 0.2s;
    white-space: nowrap;
}
.btn-cta-primary:hover { background: #c44b18; transform: translateY(-2px); }

.btn-cta-ghost {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.45);
    text-decoration: none;
    border-bottom: 1px solid rgba(255,255,255,0.15);
    padding-bottom: 1px;
    transition: color 0.2s, border-color 0.2s;
    white-space: nowrap;
}
.btn-cta-ghost:hover { color: rgba(255,255,255,0.75); border-color: rgba(255,255,255,0.4); }

/* ─── FOOTER ───────────────────────────────────────────────── */
.site-footer {
    border-top: 1px solid #c5bdb4;
    padding: 3rem 0 2rem;
}
.footer-inner {
    max-width: 1480px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
}
.footer-brand {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 1.5rem;
    font-weight: 300;
    color: #1a1a1a;
    letter-spacing: -0.02em;
}
.footer-brand em { font-style: italic; color: #e85d26; }
.footer-links {
    display: flex;
    gap: 2rem;
    list-style: none;
}
.footer-links a {
    font-size: 0.78rem;
    color: #8a7f74;
    text-decoration: none;
    letter-spacing: 0.06em;
    transition: color 0.2s;
}
.footer-links a:hover { color: #e85d26; }
.footer-copy {
    font-size: 0.72rem;
    color: #c5bdb4;
    letter-spacing: 0.06em;
}

/* ─── ANIMATIONS ───────────────────────────────────────────── */
@@keyframes riseIn {
    from { opacity: 0; transform: translateY(22px); }
    to   { opacity: 1; transform: translateY(0); }
}
@@keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
}
@@keyframes floatCard {
    from { opacity: 0; transform: translateX(-30px) scale(0.95); }
    to   { opacity: 1; transform: translateX(0) scale(1); }
}

/* Scroll reveal */
.reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.65s cubic-bezier(0.4,0,0.2,1), transform 0.65s cubic-bezier(0.4,0,0.2,1);
}
.reveal.visible {
    opacity: 1;
    transform: translateY(0);
}
.reveal-d1 { transition-delay: 0.08s; }
.reveal-d2 { transition-delay: 0.16s; }
.reveal-d3 { transition-delay: 0.24s; }
.reveal-d4 { transition-delay: 0.32s; }

/* ─── RESPONSIVE ───────────────────────────────────────────── */
@@media (max-width: 1100px) {
    .recipe-row { grid-template-columns: repeat(2, 1fr); }
    .cuisines-grid { grid-template-columns: repeat(3, 1fr); }
}

@@media (max-width: 900px) {
    .hero { grid-template-columns: 1fr; height: auto; max-height: none; }
    .hero-left {
        padding: 2rem 1.75rem;
        min-height: 60vh;
        order: 2;
    }
    .hero-right { min-height: 50vw; order: 1; }
    .editorial-split { grid-template-columns: 1fr; }
    .ed-image-side { min-height: 300px; }
    .community-inner { grid-template-columns: 1fr; gap: 2.5rem; }
    .steps-grid { grid-template-columns: 1fr 1fr; }
    .step-item { border-bottom: 1px solid #c5bdb4; }
    .cta-banner { grid-template-columns: 1fr; padding: 3rem 2rem; }
    .cta-buttons { align-items: flex-start; }
}

@@media (max-width: 600px) {
    .recipe-row { grid-template-columns: 1fr; }
    .cuisines-grid { grid-template-columns: 1fr 1fr; }
    .steps-grid { grid-template-columns: 1fr; }
    .hero-stats { gap: 1.5rem; }
    .hero-left { padding: 4rem 1.5rem 2rem; }
    .section { padding: 0 1.25rem; }
    .section-head { flex-direction: column; align-items: flex-start; }
}
</style>


