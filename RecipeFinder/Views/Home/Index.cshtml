@{
    ViewData["Title"] = "Artisan Kitchen — RecipeFinder";
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,500;0,600;1,400&family=DM+Sans:wght@300;400;500;700&display=swap" rel="stylesheet">

<style>
    /* ─── BASE RESET ─── */
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    body {
        font-family: 'DM Sans', sans-serif;
        background-color: #fdfaf6;
        color: #1a1a1a;
        line-height: 1.6;
        overflow-x: hidden;
    }

    .container {
        max-width: 1520px;
        margin: 0 auto;
        padding: 0 2.5rem;
    }

    /* ─── HERO SECTION ─── */
    .hero {
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        min-height: 95vh;
        align-items: center;
        gap: 5rem;
        padding-top: 2rem;
    }

    .hero-content {
        z-index: 10;
    }

    .eyebrow {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.35em;
        color: #e85d26;
        font-weight: 700;
        margin-bottom: 2.5rem;
        display: flex;
        align-items: center;
        gap: 1.2rem;
    }

    .eyebrow::after {
        content: '';
        height: 1px;
        width: 50px;
        background: #e85d26;
    }

    .hero-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(3.5rem, 6.5vw, 7rem);
        line-height: 0.9;
        font-weight: 300;
        margin-bottom: 2.5rem;
        letter-spacing: -0.04em;
    }

    .hero-title em {
        font-style: italic;
        color: #e85d26;
        font-weight: 400;
    }

    .hero-sub {
        font-size: 1.15rem;
        color: #6e675f;
        max-width: 500px;
        margin-bottom: 3.5rem;
        font-weight: 300;
    }

    /* Hero Bento Visuals */
    .hero-visuals {
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        grid-template-rows: repeat(12, 1fr);
        height: 85vh;
        position: relative;
    }

    .visual-box {
        overflow: hidden;
        border-radius: 2px;
        box-shadow: 0 20px 40px -15px rgba(0,0,0,0.12);
        transition: all 0.6s cubic-bezier(0.23, 1, 0.32, 1);
    }

    .visual-box img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 1.5s ease;
    }

    .visual-main {
        grid-column: 1 / 11;
        grid-row: 1 / 11;
        z-index: 2;
    }

    .visual-overlap {
        grid-column: 6 / 13;
        grid-row: 7 / 13;
        z-index: 3;
        border: 15px solid #fdfaf6;
    }

    .visual-box:hover img { transform: scale(1.1); }

    .floating-badge {
        position: absolute;
        top: 10%;
        right: -5%;
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(12px);
        padding: 2.5rem;
        border-radius: 50%;
        width: 140px;
        height: 140px;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        font-size: 0.65rem;
        font-weight: 700;
        text-transform: uppercase;
        border: 1px solid rgba(0,0,0,0.05);
        z-index: 4;
        animation: rotateBadge 25s linear infinite;
    }

    @@keyframes rotateBadge {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    /* ─── BUTTONS ─── */
    .btn {
        display: inline-flex;
        align-items: center;
        gap: 1.2rem;
        padding: 1.3rem 3rem;
        font-size: 0.85rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        text-decoration: none;
        transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
    }

    .btn-dark {
        background: #1a1a1a;
        color: #ffffff;
    }

    .btn-dark:hover {
        background: #e85d26;
        transform: translateY(-5px);
        box-shadow: 0 15px 30px rgba(232, 93, 38, 0.2);
    }

    /* ─── MARQUEE ─── */
    .marquee {
        background: #1a1a1a;
        color: #ffffff;
        padding: 1.8rem 0;
        overflow: hidden;
        white-space: nowrap;
        display: flex;
        border-radius: 4px;
        margin: 4rem 0;
    }

    .marquee-content {
        display: flex;
        animation: scroll 40s linear infinite;
    }

    .marquee-text {
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.4em;
        margin-right: 5rem;
        display: flex;
        align-items: center;
        gap: 2rem;
        opacity: 0.6;
    }

    .marquee-text::after {
        content: '✦';
        color: #e85d26;
    }

    @@keyframes scroll {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
    }

    /* ─── RECIPE CARDS ─── */
    .section-pad { padding: 10rem 0; }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 5rem;
    }

    .recipe-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
        gap: 3rem;
    }

    .recipe-card {
        text-decoration: none;
        color: inherit;
        display: block;
        transition: all 0.5s ease;
    }

    .recipe-img-container {
        aspect-ratio: 4/5;
        overflow: hidden;
        background: #f0e9dc;
        margin-bottom: 2rem;
        position: relative;
    }

    .recipe-img-container img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.8s ease;
    }

    .recipe-card:hover .recipe-img-container img {
        transform: scale(1.08);
    }

    .recipe-badge {
        position: absolute;
        top: 1.5rem;
        left: 1.5rem;
        background: rgba(255, 255, 255, 0.95);
        padding: 0.5rem 1rem;
        font-size: 0.65rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    .recipe-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: 2.2rem;
        line-height: 1.1;
        font-weight: 500;
        margin-bottom: 0.8rem;
    }

    .recipe-meta {
        font-size: 0.85rem;
        color: #6e675f;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        display: flex;
        gap: 1rem;
    }

    /* ─── RESPONSIVE ─── */
    @@media (max-width: 1024px) {
        .hero { grid-template-columns: 1fr; text-align: center; }
        .hero-content { display: flex; flex-direction: column; align-items: center; }
        .hero-sub { margin-left: auto; margin-right: auto; }
        .hero-visuals { height: 60vh; }
    }

    /* ════════════════════════════════════════════════════════════
       ADDED SECTIONS — same design language, nothing above changed
       ════════════════════════════════════════════════════════════ */

    /* ─── CUISINE GRID ─── */
    .cuisine-section { padding: 0 0 10rem; }

    .cuisine-grid {
        display: grid;
        grid-template-columns: repeat(6, 1fr);
        gap: 1.2rem;
        margin-top: 5rem;
    }

    .cuisine-tile {
        position: relative;
        aspect-ratio: 2/3;
        overflow: hidden;
        text-decoration: none;
        display: block;
    }

    .cuisine-tile img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        filter: brightness(0.65) saturate(1.1);
        transition: transform 0.9s cubic-bezier(0.23, 1, 0.32, 1), filter 0.6s ease;
    }

    .cuisine-tile:hover img {
        transform: scale(1.1);
        filter: brightness(0.5) saturate(1.2);
    }

    .cuisine-tile-label {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 1.5rem 1.2rem 1.2rem;
        background: linear-gradient(to top, rgba(26,26,26,0.9) 0%, transparent 100%);
        color: #ffffff;
    }

    .cuisine-tile-name {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.15rem;
        font-weight: 500;
        display: block;
        line-height: 1.2;
    }

    .cuisine-tile-count {
        font-size: 0.6rem;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        color: rgba(255,255,255,0.5);
        margin-top: 0.2rem;
        display: block;
    }

    @@media (max-width: 1024px) { .cuisine-grid { grid-template-columns: repeat(3, 1fr); } }
    @@media (max-width: 600px)  { .cuisine-grid { grid-template-columns: repeat(2, 1fr); } }

    /* ─── EDITORIAL SPLIT: FORUM ─── */
    .editorial {
        display: grid;
        grid-template-columns: 1fr 1fr;
        min-height: 80vh;
        margin-bottom: 10rem;
        border-radius: 4px;
        overflow: hidden;
    }

    .editorial-image {
        position: relative;
        overflow: hidden;
    }

    .editorial-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        filter: brightness(0.72) saturate(1.05);
        transition: transform 8s ease;
    }

    .editorial-image:hover img { transform: scale(1.04); }

    .editorial-image-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to right, transparent 55%, rgba(26,26,26,0.8) 100%);
    }

    .editorial-content {
        background: #1a1a1a;
        padding: 6rem 5rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .editorial-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(2.5rem, 3.5vw, 4rem);
        font-weight: 300;
        line-height: 1.05;
        color: #ffffff;
        margin: 1.5rem 0 1rem;
        letter-spacing: -0.03em;
    }

    .editorial-title em { font-style: italic; color: #e85d26; }

    .editorial-body {
        font-size: 0.95rem;
        color: rgba(255,255,255,0.45);
        font-weight: 300;
        line-height: 1.8;
        max-width: 420px;
        margin-bottom: 3rem;
    }

    /* Forum thread rows inside editorial */
    .thread-list {
        display: flex;
        flex-direction: column;
        gap: 1px;
        margin-bottom: 3rem;
        border: 1px solid rgba(255,255,255,0.07);
        border-radius: 3px;
        overflow: hidden;
        background: rgba(255,255,255,0.04);
    }

    .thread-row {
        display: flex;
        align-items: center;
        gap: 1.2rem;
        padding: 1.1rem 1.4rem;
        background: rgba(255,255,255,0.03);
        border-bottom: 1px solid rgba(255,255,255,0.05);
        text-decoration: none;
        transition: background 0.25s;
    }

    .thread-row:last-child { border-bottom: none; }
    .thread-row:hover { background: rgba(232,93,38,0.08); }

    .thread-avatar {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        background: #e85d26;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.7rem;
        font-weight: 700;
        color: #ffffff;
        flex-shrink: 0;
    }

    .thread-text { flex: 1; min-width: 0; }

    .thread-title-text {
        font-size: 0.85rem;
        font-weight: 500;
        color: rgba(255,255,255,0.8);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        margin-bottom: 0.2rem;
    }

    .thread-sub {
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: rgba(255,255,255,0.25);
        display: flex;
        gap: 0.75rem;
    }

    .thread-hot { color: #e85d26; }

    .thread-replies {
        font-size: 0.7rem;
        font-weight: 700;
        color: rgba(255,255,255,0.3);
        flex-shrink: 0;
        text-align: right;
    }

    .btn-outline-light {
        display: inline-flex;
        align-items: center;
        gap: 1rem;
        padding: 1.1rem 2.5rem;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        text-decoration: none;
        border: 1px solid rgba(255,255,255,0.18);
        color: rgba(255,255,255,0.7);
        transition: all 0.35s ease;
        align-self: flex-start;
    }

    .btn-outline-light:hover {
        border-color: #e85d26;
        color: #e85d26;
        transform: translateY(-3px);
    }

    @@media (max-width: 1024px) {
        .editorial { grid-template-columns: 1fr; }
        .editorial-image { min-height: 40vh; }
        .editorial-content { padding: 4rem 2.5rem; }
    }

    /* ─── COMMUNITY MEMBERSHIP BAND ─── */
    .membership-band {
        background: #f0e8da;
        border-top: 1px solid #ddd5c8;
        border-bottom: 1px solid #ddd5c8;
        padding: 8rem 0;
        margin-bottom: 10rem;
    }

    .membership-inner {
        max-width: 1520px;
        margin: 0 auto;
        padding: 0 2.5rem;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8rem;
        align-items: center;
    }

    .membership-headline {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(2.8rem, 4.5vw, 5.5rem);
        font-weight: 300;
        line-height: 0.95;
        letter-spacing: -0.04em;
        color: #1a1a1a;
        margin: 1.5rem 0 2rem;
    }

    .membership-headline em { font-style: italic; color: #e85d26; }

    .membership-body {
        font-size: 1rem;
        color: #6e675f;
        font-weight: 300;
        line-height: 1.8;
        max-width: 440px;
        margin-bottom: 3rem;
    }

    .perks-list {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 1.2rem;
        margin-bottom: 3.5rem;
    }

    .perk-item {
        display: flex;
        align-items: flex-start;
        gap: 1.2rem;
        font-size: 0.9rem;
        color: #3a3530;
        line-height: 1.5;
    }

    .perk-icon {
        width: 30px;
        height: 30px;
        border-radius: 50%;
        background: #fdfaf6;
        border: 1px solid rgba(232,93,38,0.22);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.7rem;
        flex-shrink: 0;
        margin-top: 0.1rem;
    }

    /* Stacked forum preview on right */
    .membership-forum {
        display: flex;
        flex-direction: column;
        gap: 1px;
        border: 1px solid #d5cfc8;
        border-radius: 3px;
        overflow: hidden;
        background: #d5cfc8;
    }

    .mforum-row {
        background: #fdfaf6;
        display: flex;
        align-items: center;
        gap: 1.2rem;
        padding: 1.2rem 1.6rem;
        text-decoration: none;
        transition: background 0.2s;
    }

    .mforum-row:hover { background: #fef0e8; }
    .mforum-row:hover .mforum-title { color: #e85d26; }

    .mforum-avatar {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        background: linear-gradient(135deg, #e85d26, #f5a87a);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.72rem;
        font-weight: 700;
        color: #ffffff;
        flex-shrink: 0;
    }

    .mforum-content { flex: 1; min-width: 0; }

    .mforum-title {
        font-size: 0.88rem;
        font-weight: 500;
        color: #1a1a1a;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        transition: color 0.2s;
        margin-bottom: 0.2rem;
    }

    .mforum-meta {
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #9e9890;
        display: flex;
        gap: 0.75rem;
        align-items: center;
    }

    .mforum-tag {
        background: #f0e9dc;
        padding: 0.1rem 0.5rem;
        border-radius: 2px;
        font-weight: 700;
        color: #6e675f;
        font-size: 0.6rem;
    }

    .mforum-count {
        font-size: 0.72rem;
        font-weight: 700;
        color: #9e9890;
        flex-shrink: 0;
        text-align: right;
    }

    @@media (max-width: 1024px) {
        .membership-inner { grid-template-columns: 1fr; gap: 4rem; }
    }

    /* ─── CTA CLOSE ─── */
    .cta-close {
        background: #1a1a1a;
        border-radius: 4px;
        padding: 8rem 6rem;
        display: grid;
        grid-template-columns: 1fr auto;
        align-items: center;
        gap: 4rem;
        margin-bottom: 8rem;
        position: relative;
        overflow: hidden;
    }

    .cta-close::before {
        content: 'COOK';
        position: absolute;
        right: -0.05em;
        top: 50%;
        transform: translateY(-50%);
        font-family: 'Cormorant Garamond', serif;
        font-size: 18rem;
        font-weight: 300;
        color: transparent;
        -webkit-text-stroke: 1px rgba(255,255,255,0.035);
        line-height: 1;
        pointer-events: none;
        user-select: none;
        letter-spacing: -0.05em;
    }

    .cta-close-label {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.35em;
        color: #e85d26;
        font-weight: 700;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .cta-close-label::after { content: ''; height: 1px; width: 40px; background: #e85d26; }

    .cta-close-headline {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(2.5rem, 3.5vw, 4rem);
        font-weight: 300;
        color: #ffffff;
        line-height: 1.0;
        letter-spacing: -0.03em;
    }

    .cta-close-headline em { font-style: italic; color: #e85d26; }

    .cta-close-actions {
        display: flex;
        flex-direction: column;
        gap: 1.2rem;
        align-items: flex-end;
        flex-shrink: 0;
        position: relative;
        z-index: 2;
    }

    .btn-accent {
        display: inline-flex;
        align-items: center;
        gap: 1rem;
        padding: 1.3rem 3rem;
        font-size: 0.85rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        text-decoration: none;
        background: #e85d26;
        color: #ffffff;
        transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
        white-space: nowrap;
    }

    .btn-accent:hover {
        background: #c44b18;
        transform: translateY(-4px);
        box-shadow: 0 15px 30px rgba(232, 93, 38, 0.3);
    }

    .cta-sublink {
        font-size: 0.75rem;
        color: rgba(255,255,255,0.35);
        text-decoration: none;
        border-bottom: 1px solid rgba(255,255,255,0.12);
        padding-bottom: 1px;
        transition: color 0.2s, border-color 0.2s;
        white-space: nowrap;
    }

    .cta-sublink:hover { color: rgba(255,255,255,0.65); border-color: rgba(255,255,255,0.4); }

    @@media (max-width: 1024px) {
        .cta-close { grid-template-columns: 1fr; padding: 5rem 3rem; }
        .cta-close-actions { align-items: flex-start; }
    }
</style>


<main class="container">
    <section class="hero">
        <div class="hero-content">
            <div class="eyebrow">The Global Culinary Journal</div>
            <h1 class="hero-title">
                Cook with <em>Purpose</em>.<br>
                Live with Flavor.
            </h1>
            <p class="hero-sub">
                A curated sanctuary for the home chef. Discover artisanal recipes from across the globe, refine your technique, and archive your kitchen triumphs.
            </p>
            <div class="hero-actions">
                <a href="/Recipe" class="btn btn-dark">Explore the Archive</a>
            </div>
            
            <div style="margin-top: 6rem; display: flex; gap: 5rem;">
                <div>
                    <span style="display:block; font-family:'Cormorant Garamond'; font-size: 3rem; color: #1a1a1a;">200+</span>
                    <span style="font-size:0.65rem; text-transform:uppercase; letter-spacing:0.2em; color:#6e675f; font-weight:700;">Artisan Recipes</span>
                </div>
                <div>
                    <span style="display:block; font-family:'Cormorant Garamond'; font-size: 3rem; color: #1a1a1a;">34</span>
                    <span style="font-size:0.65rem; text-transform:uppercase; letter-spacing:0.2em; color:#6e675f; font-weight:700;">Global Cuisines</span>
                </div>
            </div>
        </div>

        <div class="hero-visuals">
            <div class="floating-badge">Member <br> Favorite</div>
            <div class="visual-box visual-main">
                <img src="https://images.unsplash.com/photo-1504674900247-0877df9cc836?w=1200&q=80" alt="Plated Salmon">
            </div>
            <div class="visual-box visual-overlap">
                <img src="https://images.unsplash.com/photo-1555939594-58d7cb561ad1?w=800&q=80" alt="Fresh Grilling">
            </div>
        </div>
    </section>
</main>

<div class="marquee">
    <div class="marquee-content">
        @for(int i=0; i<3; i++) {
            <span class="marquee-text">Mediterranean Kitchen</span>
            <span class="marquee-text">Japanese Umami</span>
            <span class="marquee-text">Rustic Italian</span>
            <span class="marquee-text">Oaxacan Spice</span>
            <span class="marquee-text">Nordic Minimalism</span>
        }
    </div>
</div>







<!-- BROWSE BY CUISINE ══════════════════════════════════════════════════════════════════ -->
<section class="container cuisine-section">
    <header class="section-header">
        <div>
            <div class="eyebrow">34 Global Cuisines</div>
            <h2 style="font-family:'Cormorant Garamond'; font-size: 4rem; font-weight: 300; letter-spacing:-0.03em;">Browse by <em>Origin</em></h2>
        </div>
