                new { Name="Italian",    Count="24", Img="https://images.unsplash.com/photo-1498579150354-977475b7ea0b?w=600&q=80" },
                new { Name="Japanese",   Count="18", Img="https://images.unsplash.com/photo-1553621042-f6e147245754?w=600&q=80" },
                new { Name="Mexican",    Count="15", Img="https://images.unsplash.com/photo-1565299585323-38d6b0865b47?w=600&q=80" },
                new { Name="French",     Count="12", Img="https://images.unsplash.com/photo-1414235077428-338989a2e8c0?w=600&q=80" },
                new { Name="Indian",     Count="21", Img="https://images.unsplash.com/photo-1585937421612-70a008356fbe?w=600&q=80" },
                new { Name="Thai",       Count="14", Img="https://images.unsplash.com/photo-1559314809-0d155014e29e?w=600&q=80" },
