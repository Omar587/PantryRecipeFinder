    width: 26px;
    height: 26px;
    border-radius: 50%;
    border: 1px solid rgba(232,93,38,0.35);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.65rem;
    color: #e85d26;
    flex-shrink: 0;
    margin-top: 1px;
    transition: box-shadow 0.25s ease, border-color 0.25s ease;
}
</style>

<script>
// Scroll reveal — elements fade up as they enter the viewport
const toReveal = document.querySelectorAll('.cuisine-tile, .recipe-card, .thread-row, .mforum-row, .perk-item');
const revealObs = new IntersectionObserver((entries) => {
    entries.forEach((e, i) => {
        if (e.isIntersecting) {
            e.target.style.transitionDelay = `${(i % 6) * 60}ms`;
            e.target.classList.add('in-view');
            revealObs.unobserve(e.target);
        }
    });
}, { threshold: 0.08, rootMargin: '0px 0px -30px 0px' });

toReveal.forEach(el => {
    el.style.opacity = '0';
    el.style.transform = 'translateY(24px)';
    el.style.transition = 'opacity 0.65s cubic-bezier(0.23,1,0.32,1), transform 0.65s cubic-bezier(0.23,1,0.32,1)';
    revealObs.observe(el);
});

document.addEventListener('animationend', () => {}, { once: true });

// When in-view class added, animate
document.querySelectorAll('.cuisine-tile, .recipe-card, .thread-row, .mforum-row, .perk-item').forEach(el => {
    new MutationObserver(() => {
        if (el.classList.contains('in-view')) {
            el.style.opacity = '1';
            el.style.transform = 'translateY(0)';
        }
    }).observe(el, { attributes: true, attributeFilter: ['class'] });
});
</script>